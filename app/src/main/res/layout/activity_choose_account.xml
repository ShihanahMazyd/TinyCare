<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="28dp"
    android:background="@color/tinycare_bg">

    <ImageView
        android:layout_width="170dp"
        android:layout_height="170dp"
        android:src="@drawable/tinycare_logo"
        android:contentDescription="TinyCare Logo" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Choose Account Type"
        android:textSize="28sp"
        android:textStyle="bold"
        android:textColor="@color/tinycare_dark"
        android:layout_marginTop="20dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Select how you want to continue"
        android:textSize="15sp"
        android:textColor="@color/tinycare_hint"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="32dp" />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/nurseryButton"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Nursery / Teacher"
        android:textAllCaps="false"
        android:textSize="16sp"
        android:textColor="#FFFFFF"
        android:background="@drawable/button_background" />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/parentButton"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Parent"
        android:textAllCaps="false"
        android:textSize="16sp"
        android:textColor="@color/tinycare_dark"
        android:background="@drawable/secondary_button_background"
        android:layout_marginTop="14dp" />

</LinearLayout>