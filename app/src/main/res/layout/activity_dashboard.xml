<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/tinycare_bg">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/topAppBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/tinycare_dark"
        android:title="TinyCare Dashboard"
        android:titleTextColor="@android:color/white"
        app:menu="@menu/toolbar_menu" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp"
            android:gravity="center_horizontal">

            <ImageView
                android:layout_width="130dp"
                android:layout_height="130dp"
                android:src="@drawable/tinycare_logo"
                android:contentDescription="TinyCare Logo"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Welcome back, Teacher"
                android:textSize="16sp"
                android:textColor="@color/tinycare_hint"
                android:layout_marginBottom="28dp" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/addChildButton"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="Add Child"
                android:textAllCaps="false"
                android:textSize="17sp"
                android:textColor="#FFFFFF"
                android:background="@drawable/button_background" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/childrenButton"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="Children List"
                android:textAllCaps="false"
                android:textSize="17sp"
                android:textColor="#FFFFFF"
                android:background="@drawable/button_background"
                android:layout_marginTop="14dp" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/attendanceButton"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="Attendance"
                android:textAllCaps="false"
                android:textSize="17sp"
                android:textColor="#FFFFFF"
                android:background="@drawable/button_background"
                android:layout_marginTop="14dp" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/reportsButton"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:text="Daily Reports"
                android:textAllCaps="false"
                android:textSize="17sp"
                android:textColor="#FFFFFF"
                android:background="@drawable/button_background"
                android:layout_marginTop="14dp" />

        </LinearLayout>

    </ScrollView>

</LinearLayout>